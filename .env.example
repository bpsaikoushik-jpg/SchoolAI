# Database Configuration
POSTGRES_USER=schoolai
POSTGRES_PASSWORD=schoolai_password
POSTGRES_DB=schoolai_db
DATABASE_URL=postgresql://schoolai:schoolai_password@db:5432/schoolai_db

# Security
JWT_SECRET=generate_a_secure_random_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# API Configuration
PROJECT_NAME=SchoolAI
VITE_API_URL=http://localhost:8000/api/v1

# AI Intelligence Engine - Provider Layer
# AI_PROVIDER selects the active provider: openai | gemini | claude
AI_PROVIDER=openai
# Optional ordered fallback chain tried if the primary provider fails, e.g. "gemini,claude"
AI_FALLBACK_PROVIDERS=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=1.0
AI_MAX_OUTPUT_TOKENS=1200
